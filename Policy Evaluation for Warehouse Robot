grid = [
    [0, 2, 0],
    [0, -2, 0],
    [0, 0, 5]
]

rows, cols = 3, 3
V = [[0.0 for j in range(cols)] for i in range(rows)]

gamma = 0.9

for k in range(20):   # iterations
    newV = [[0.0 for j in range(cols)] for i in range(rows)]

    for i in range(rows):
        for j in range(cols):

            if j < cols - 1:
                ni, nj = i, j + 1
            elif i < rows - 1:
                ni, nj = i + 1, j
            else:
                ni, nj = i, j

            reward = grid[ni][nj]
            newV[i][j] = reward + gamma * V[ni][nj]

    V = newV

print("Value Function:")
for row in V:
    print(["%.2f" % x for x in row])
